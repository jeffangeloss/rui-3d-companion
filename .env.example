# ─────────────────────────────────────────────────────────────
# Rui 3D Companion — local-first configuration
# Copy this file to `.env.local` and adjust to your machine.
# Everything runs locally; no cloud keys required.
# ─────────────────────────────────────────────────────────────

# ── Chat (Ollama) ────────────────────────────────────────────
# Run: `ollama serve` then `ollama pull llama3.1` (or your model).
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Temperature / creativity for Rui's theatrical replies.
OLLAMA_TEMPERATURE=0.8

# ── Text-to-Speech (Piper) ───────────────────────────────────
# Piper is a local neural TTS. Download a voice (.onnx + .onnx.json)
# from https://github.com/rhasspy/piper/releases and point to it.
# The /api/tts route spawns the Piper binary by default.
PIPER_BIN=piper
PIPER_MODEL=/absolute/path/to/voice.onnx
# Optional: speaker id for multi-speaker voices.
PIPER_SPEAKER_ID=

# Alternatively, proxy to a Piper HTTP server instead of spawning the binary.
# If set, this takes precedence over PIPER_BIN. Expected to return audio/wav.
# PIPER_HTTP_URL=http://localhost:5000

# ── Speech-to-Text (Whisper) ─────────────────────────────────
# Point to any OpenAI-compatible transcription endpoint, e.g.
# faster-whisper-server or whisper.cpp's server (`./server --convert`).
WHISPER_HTTP_URL=http://localhost:8000/v1/audio/transcriptions
WHISPER_MODEL=Systran/faster-whisper-base
# Language hint (ISO code) — Rui's companion Gaby speaks Spanish.
WHISPER_LANGUAGE=es

# ── Avatar ───────────────────────────────────────────────────
# Path (relative to /public) of the VRM model. Keep the actual .vrm
# file OUT of git — see public/models/README.md.
NEXT_PUBLIC_VRM_PATH=/models/rui-local.vrm
